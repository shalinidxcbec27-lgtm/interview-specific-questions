import java.util.Arrays;

public class Main {
    public static void sortZerosAndOnes(int[] arr) {
        int left = 0;
        int right = arr.length - 1;

        while (left < right) {
            // Move left pointer forward if it points to 0
            while (arr[left] == 0 && left < right) {
                left++;
            }
            // Move right pointer backward if it points to 1
            while (arr[right] == 1 && left < right) {
                right--;
            }
            // If pointers haven't crossed, swap the 1 at left with the 0 at right
            if (left < right) {
                arr[left] = 0;
                arr[right] = 1;
                left++;
                right--;
            }
        }
    }

    public static void main(String[] args) {
        int[] input = {1, 0, 1, 1, 0, 1, 0, 1, 0, 0, 0, 1, 0, 1};
        
        System.out.println("Original Array: " + Arrays.toString(input));
        sortZerosAndOnes(input);
        System.out.println("Sorted Array:   " + Arrays.toString(input));
    }
}
