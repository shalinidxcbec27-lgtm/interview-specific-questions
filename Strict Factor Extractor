import java.util.Scanner;

public class factorExtract {
    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        int n = in.nextInt();
        if (n == 0) {
            System.out.println("No Factors");
        } else {
            n = Math.abs(n);
            for (int i = 1; i <= n; i++) {
                if (n % i == 0) System.out.print(i + " ");
            }
        }
        in.close();
    }
}
