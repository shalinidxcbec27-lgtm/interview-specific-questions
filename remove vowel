import java.util.*;

public class Main {
    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        
        System.out.print("Enter a string: ");
        String input = in.nextLine(); 
        String result = input.replaceAll("[aeiouAEIOU]", "");
        
        System.out.println(result);
        
        in.close();
    }
}
