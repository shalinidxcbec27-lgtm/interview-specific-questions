import java.util.Scanner;

public class CoreQ7 {
    public static void main(String[] args) {
        Scanner in = new Scanner(System.in);
        int n = in.nextInt();
        for (int i = 0; i < n; i++) {
            char symbol = (i % 2 == 0) ? '1' : '0';
            for (int j = 0; j < (n - i); j++) {
                System.out.print(symbol);
            }
            System.out.println();
        }
        in.close();
    }
}
