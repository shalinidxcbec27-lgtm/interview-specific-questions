public class Main {
    public static int findLengthRecursive(String str) {
        // Base Case: If the string is empty, return 0
        if (str.equals("")) {
            return 0;
        }
        // Recursive Case: Add 1 for the current character and cut it off
        return 1 + findLengthRecursive(str.substring(1));
    }

    public static void main(String[] args) {
        String testStr = "JavaProgramming";
        
        int length = findLengthRecursive(testStr);
        System.out.println("The string is: '" + testStr + "'");
        System.out.println("The calculated length is: " + length);
    }
}
